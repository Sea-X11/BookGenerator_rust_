# 提供服务后端的 API 类型, 可选: gemini 或 ollama
API_TYPE="ollama"

# API Base URL
# Gemini 默认: https://generativelanguage.googleapis.com/v1beta/models
# Ollama 默认: http://127.0.0.1:11434/api/generate
API_BASE_URL="http://127.0.0.1:11434/api/generate"

# 模型名称
# Gemini 默认: gemini-2.0-pro-exp-02-05
# Ollama 示例: qwen2.5 (或者 llama3 等你在本地安装的模型)
MODEL="gemma3:latest"

# 如果使用 Gemini, 请在此处填写你的 API Key
GEMINI_API_KEY="AIzaSyBC7UZWOPl0KLdkSgTzIEGnG_i6JNu9WfI"

# 代理设置（可选，仅用于 Gemini 模式）
# 如果你需要代理访问 Gemini，取消注释并填写代理地址，例如：
# PROXY_URL="http://127.0.0.1:7890"
#PROXY_URL="http://127.0.0.1:7890"
# 如果留空或不填，将不使用代理（直连）
